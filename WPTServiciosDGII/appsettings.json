{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "WptDatabase": "Server=WPT-DEVSERVER;Database=WPTexecutorDB;User Id=sa;Password=zeus;TrustServerCertificate=True;"
  },
  "AppSettings": {
    "InstanceName": "WPT-Base",
    "BaseUrl": "https://cloud.wptsoftwares.net",
    "AltBaseUrl": "https://wptsoftwares.giize.com/WPTexecutor",
    "AllowedOrigins": [
      "https://cloud.wptsoftwares.net",
      "https://wptsoftwares.giize.com"
    ]
  },

  // ── FASE 0: Configuración de BD Externa Dinámica ───────────────────────────
  // Registra una o más BDs externas. El header X-Db-Tenant selecciona cuál usar.
  // NO hardcodear credenciales de producción aquí; usar variables de entorno o
  // appsettings.Production.json (excluido del repositorio con .gitignore).
  "ExternalDbConfig": {
    "DefaultTenant": "comercial",
    "Tenants": {
      "comercial": {
        "ConnectionString": "Server=WPT-DEVSERVER;Database=WPTcomercial;User Id=sa;Password=zeus;TrustServerCertificate=True;",
        "Description": "BD comercial WPT — multi-empresa por NucleoRNC"
      }
    }
  },

  // ── FASE 0: Mapeo de columnas de la tabla Nucleo ────────────────────────────
  // Cuando conozcas los nombres reales, cambia los valores aquí sin recompilar.
  "NucleoConfig": {
    "TableName": "Nucleo",
    "ColumnId": "NucleoID",
    "ColumnRnc": "NucleoRNC",
    "ColumnEstado": "NucleoEstado",
    "ColumnRutaCertificado": "NucleoCertificadoDigital",
    "ColumnPasswordCertificado": "NucleoPasswordDigital",
    "EstadoActivo": "A"
  },

  // ── FASE 0: Configuración de certificados .p12 ──────────────────────────────
  "CertificadosConfig": {
    "RutaBase": "C:\\Certificados\\WPT",
    "FailFast": true,
    "TimeoutCargaMs": 5000
  }
}
